# LightRAG Configuration - Production Setup
# Storage: Redis (KV) + Neo4j (Graph) + Milvus (Vector) + PostgreSQL (DocStatus)

# =====================
# Server Configuration
# =====================
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE='但问智能知识库'
WEBUI_DESCRIPTION="Simple and Fast Graph Based RAG System"
# WORKERS=2
# TIMEOUT=150

# =====================
# Space Management (Multi-Tenant)
# =====================
SPACE_MANAGEMENT_ENABLED=true
# JWT_ALGORITHM=HS256
# TOKEN_EXPIRE_HOURS=48

# =====================
# LLM: DeepSeek (OpenAI-compatible)
# =====================
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.deepseek.com/v1
LLM_BINDING_API_KEY=sk-205ce261594a495b96b4f99bebcac240
LLM_MODEL=deepseek-v4-flash
# LLM_TIMEOUT=180

# =====================
# Embedding: DashScope (阿里云百炼)
# =====================
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BINDING_API_KEY=sk-855e3a0919b543ffb2f8ccb2e5ea1d53
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
EMBEDDING_TIMEOUT=600

# =====================
# Reranking: DashScope (阿里云百炼)
# =====================
RERANK_BINDING=aliyun
RERANK_MODEL=gte-rerank-v2
RERANK_BINDING_HOST=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_BINDING_API_KEY=sk-855e3a0919b543ffb2f8ccb2e5ea1d53
MIN_RERANK_SCORE=0.0
RERANK_BY_DEFAULT=True
RELATED_CHUNK_NUMBER=6

# =====================
# Query Defaults
# =====================
TOP_K=40
CHUNK_TOP_K=20
MAX_ENTITY_TOKENS=6000
MAX_RELATION_TOKENS=8000
MAX_TOTAL_TOKENS=30000
KG_CHUNK_PICK_METHOD=VECTOR
# ENABLE_LLM_CACHE=true

# =====================
# Document Processing
# =====================
ENABLE_LLM_CACHE_FOR_EXTRACT=true
ENABLE_MULTIMODAL_PROCESSING=true
SUMMARY_LANGUAGE=Chinese
MULTIMODAL_PARSER=docling
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100
MAX_EXTRACT_INPUT_TOKENS=61440

# =====================
# Vision Model (for Multimodal Document Processing)
# =====================
# Used for processing images, tables, and equations in documents
# If not set, will fallback to LLM_BINDING configuration
VL_BINDING=openai
VL_MODEL=doubao-seed-1-6-vision-250815
VL_BINDING_HOST=https://ark.cn-beijing.volces.com/api/v3
VL_BINDING_API_KEY=62f7c0e3-2ea5-4323-9f30-b9c62c074e37

# =====================
# RAGAnything Document Parsing
# =====================
PARSE_METHOD=auto
OUTPUT_DIR=./output
PARSER=docling
DISPLAY_CONTENT_STATS=true
ENABLE_IMAGE_PROCESSING=true
ENABLE_TABLE_PROCESSING=true
ENABLE_EQUATION_PROCESSING=true
RAGANYTHING_PROMPT_LANGUAGE=zh
MAX_CONCURRENT_FILES=3

# =====================
# Timeout Settings
# =====================
WORKER_TIMEOUT=300
FUNC_TIMEOUT=300

# =====================
# Concurrency
# =====================
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2
# EMBEDDING_FUNC_MAX_ASYNC=8
# EMBEDDING_BATCH_NUM=10

# =====================
# Storage Backend Selection
# =====================
LIGHTRAG_KV_STORAGE=RedisKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_VECTOR_STORAGE=MilvusVectorDBStorage

# =====================
# Redis (localhost:6379, no auth)
# =====================
REDIS_URI=redis://localhost:6379
REDIS_SOCKET_TIMEOUT=50
REDIS_CONNECT_TIMEOUT=60
REDIS_MAX_CONNECTIONS=100
REDIS_RETRY_ATTEMPTS=3

# =====================
# Neo4j (localhost:7687)
# =====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=twf65132090TWF
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=100
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=30
NEO4J_MAX_TRANSACTION_RETRY_TIME=30
NEO4J_MAX_CONNECTION_LIFETIME=300
NEO4J_LIVENESS_CHECK_TIMEOUT=30
NEO4J_KEEP_ALIVE=true

# =====================
# Milvus (localhost:19530, no auth)
# =====================
MILVUS_URI=http://localhost:19530
MILVUS_DB_NAME=lightrag
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_METRIC_TYPE=COSINE

# =====================
# PostgreSQL (localhost:5432)
# =====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=twf65132090TWF
POSTGRES_DATABASE=postgres
POSTGRES_MAX_CONNECTIONS=12
POSTGRES_ENABLE_VECTOR=false
