# ==========================================================================
# AI Test Agent 演示/测试环境配置
# 用法: bash deploy/deploy-demo.sh（首次运行自动生成 .env 并填充随机密码）
# 说明: LangGraph 用 in-memory 模式；无 RAG/Redis/MinIO/Mongo，仅 5 个容器
# ==========================================================================

# ---------- 镜像与端口 ----------
APP_IMAGE_TAG=demo
HTTP_PORT=80

# ---------- PostgreSQL（仅 backend 业务表，不含 langgraph 状态） ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__AUTO__                  # 部署时自动生成
POSTGRES_DB=ai_test_platform_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- 应用基础 ----------
APP_NAME=智能测试平台
APP_VERSION=2.0.0
APP_PORT=8001
DEBUG=false
API_PREFIX=/api/v2
SECRET_KEY=__AUTO__                         # 部署时自动生成（JWT 签名密钥）
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
TESTAGENT_SECRET_KEY=__AUTO__               # 部署时自动生成
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_USER_EMAIL=admin@test.com
DEFAULT_USER_NAME=管理员
AUTH_DEV_SECRET=
AUTH_AUDIENCE=
CORS_ORIGINS=["http://localhost"]
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW=60
PAGINATION_DEFAULT_SIZE=30
PAGINATION_MAX_SIZE=300
ATTACHMENT_MAX_SIZE=52428800

# ---------- MongoDB（demo 不部署，给空值避免启动报错） ----------
MONGODB_HOST=
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_DB=ai_test_management

# ---------- MinIO（demo 不部署，给兜底值防止 compose 解析报错） ----------
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=test-management
MINIO_SECURE=false
MINIO_REGION=

# ---------- 大语言模型 ----------
DEEPSEEK_API_KEY=CHANGE_ME_deepseek_key     # 【!】DeepSeek API key
LLM_MODEL=deepseek-v4-flash
IMAGE_PARSER_API_BASE=https://ark.cn-beijing.volces.com/api/v3
IMAGE_PARSER_API_KEY=CHANGE_ME_image_parser_key  # 【!】图片解析 key（可选）
IMAGE_PARSER_MODEL=doubao-seed-2-0-mini-260428
ENABLE_PDF_MULTIMODAL=true

# ---------- Agent 运行时 ----------
WEB_MCP_HEADLESS=true

# ---------- RAG（精简版：本地存储，仅需 docling + lightrag + rag-server） ----------
# 以下给兜底值，防止 docker compose 解析 compose 文件时因变量缺失报错
# （demo 无这些服务，值仅用于占位，不会被实际连接）
NEO4J_PASSWORD=demo-neo4j-placeholder
REDIS_URI=redis://placeholder:6379
RAG_MCP_URL=http://rag-server:8008/sse
RAG_USERNAME=admin
RAG_PASSWORD=__AUTO__                       # 部署时自动生成
RAG_SPACE_ID=cmp_space
LIGHTRAG_PUBLISH_PORT=9621
HF_ENDPOINT=https://hf-mirror.com
DOCLING_MEMORY_LIMIT=2G                     # docling 容器内存上限，2GB 机器会自动降为 512m

# ---------- 前端构建参数 ----------
NEXT_PUBLIC_LANGGRAPH_API_URL=http://AUTO_DETECT_IP/langgraph
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_TESTCASE_GENERATOR_ASSISTANT_ID=testcase_generator_agent
