# ==========================================================================
# AI Test Agent 生产环境配置
# 用法: cp .env.production.example .env 后修改
# 标记: 【!】= 必须修改   【?】= 按需修改   无标记 = 默认即可
# 本文件同时被两处使用（单一事实源）:
#   1) docker compose 变量插值（POSTGRES_*/MINIO_*/NEXT_PUBLIC_* 等）
#   2) app 容器 env_file（langgraph/backend/rag-server 三个服务）
# ==========================================================================

# ---------- 镜像与端口 ----------
APP_IMAGE_TAG=latest
HTTP_PORT=80                                # 【?】服务器 80 被占用时改

# ---------- PostgreSQL（LangGraph 存储与业务库共用同一数据库） ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_pg_password     # 【!】
POSTGRES_DB=ai_test_platform_db
POSTGRES_HOST=postgres                      # compose 服务名，勿改
POSTGRES_PORT=5432
# 注: POSTGRES_URI 由 compose 从上面分量自动派生注入 langgraph 容器，无需在此维护

# ---------- MongoDB（无认证，仅内部网络可达） ----------
MONGODB_HOST=mongo
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_DB=ai_test_management

# ---------- Redis ----------
REDIS_URI=redis://redis:6379

# ---------- MinIO ----------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_user       # 【!】（同时是 console 登录名）
MINIO_SECRET_KEY=CHANGE_ME_minio_password   # 【!】至少 8 位
MINIO_BUCKET=test-management
MINIO_SECURE=false
MINIO_REGION=

# ---------- 应用基础 ----------
APP_NAME=智能测试平台
APP_VERSION=2.0.0
APP_PORT=8001
DEBUG=false                                 # 生产必须 false（建表由 backend entrypoint 负责）
API_PREFIX=/api/v2
SECRET_KEY=CHANGE_ME_jwt_secret             # 【!】生成: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
TESTAGENT_SECRET_KEY=CHANGE_ME_fernet_key   # 【!】生成: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_USER_EMAIL=admin@test.com
DEFAULT_USER_NAME=管理员
AUTH_DEV_SECRET=
AUTH_AUDIENCE=
CORS_ORIGINS=["http://localhost"]           # 同源部署实际不触发 CORS，可留默认
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW=60
PAGINATION_DEFAULT_SIZE=30
PAGINATION_MAX_SIZE=300
ATTACHMENT_MAX_SIZE=52428800

# ---------- 大语言模型 ----------
DEEPSEEK_API_KEY=CHANGE_ME_deepseek_key     # 【!】
LLM_MODEL=deepseek-chat
IMAGE_PARSER_API_BASE=https://ark.cn-beijing.volces.com/api/v3   # 【?】图片解析模型（豆包 Vision 等 OpenAI 兼容接口）
IMAGE_PARSER_API_KEY=CHANGE_ME_image_parser_key                  # 【?】
IMAGE_PARSER_MODEL=doubao-seed-2-0-mini-260428                   # 【?】
ENABLE_PDF_MULTIMODAL=true

# ---------- LangSmith 可观测性（默认关闭） ----------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=new-agent

# ---------- Agent 运行时 ----------
WEB_MCP_HEADLESS=true                       # 容器无 DISPLAY；代码也会自动降级，显式更稳

# ---------- 前端构建参数（docker compose build 时插值进 ui 镜像，改后必须重建 ui） ----------
NEXT_PUBLIC_LANGGRAPH_API_URL=http://SERVER_IP_OR_DOMAIN/langgraph   # 【!】改成服务器地址（保留 /langgraph 后缀）
NEXT_PUBLIC_API_URL=                        # 留空 = 浏览器走同源相对路径（推荐，经 nginx → backend）
NEXT_PUBLIC_TESTCASE_GENERATOR_ASSISTANT_ID=testcase_generator_agent
# 注: API_INTERNAL_URL 不在此——它是 ui 容器运行时变量，compose 中固定为 http://backend:8001

# ---------- RAG 服务链（testcase agent → rag-server:8008 → lightrag:9621 → milvus/neo4j/pg/redis + docling:5001） ----------
# testcase agent 连接 rag-server 的 SSE 地址（document_tools.py 读取，容器内固定为 rag-server 服务名）
RAG_MCP_URL=http://rag-server:8008/sse
# rag-server 登录 LightRAG 的凭据：必须与 deploy/lightrag/.env 的 AUTH_ACCOUNTS 一致
RAG_USERNAME=admin
RAG_PASSWORD=CHANGE_ME_lightrag_admin_password    # 【!】
RAG_SPACE_ID=cmp_space                            # 需在 LightRAG WebUI 中已创建的 space
# Neo4j（LightRAG 图谱存储）密码
NEO4J_PASSWORD=CHANGE_ME_neo4j_password           # 【!】必须与 deploy/lightrag/.env 的 NEO4J_PASSWORD 一致
# LightRAG 知识库 WebUI 直接暴露端口（已配 AUTH_ACCOUNTS 认证）；改端口写这里，不想暴露则删 compose 中 lightrag 的 ports 段
LIGHTRAG_PUBLISH_PORT=9621
# docling 模型下载镜像（国内默认 hf-mirror；海外改 https://huggingface.co）
HF_ENDPOINT=https://hf-mirror.com
# LightRAG 自身的 LLM/Embedding/Rerank/VLM key 在 deploy/lightrag/.env 中配置（见其 .env.example）
