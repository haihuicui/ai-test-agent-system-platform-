# ==========================================================================
# AI Test Agent 生产环境配置
# 用法: bash deploy/deploy.sh（首次运行自动生成 .env 并填充随机密码）
# 标记: 【!】= 外部 API key，需手动填写   【?】= 按需修改   无标记 = 默认即可
# 其余密码/密钥由 deploy.sh 首次运行时自动生成，无需手工修改
# ==========================================================================

# ---------- 镜像与端口 ----------
APP_IMAGE_TAG=latest
HTTP_PORT=80                                # 【?】服务器 80 被占用时改

# ---------- PostgreSQL（LangGraph 存储与业务库共用同一数据库） ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__AUTO__                  # 部署时自动生成随机密码
POSTGRES_DB=ai_test_platform_db
POSTGRES_HOST=postgres                      # compose 服务名，勿改
POSTGRES_PORT=5432

# ---------- MongoDB（无认证，仅内部网络可达） ----------
MONGODB_HOST=mongo
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_DB=ai_test_management

# ---------- Redis ----------
REDIS_URI=redis://redis:6379

# ---------- MinIO ----------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=__AUTO__                   # 部署时自动生成（同时是 console 登录名）
MINIO_SECRET_KEY=__AUTO__                   # 部署时自动生成
MINIO_BUCKET=test-management
MINIO_SECURE=false
MINIO_REGION=

# ---------- 应用基础 ----------
APP_NAME=智能测试平台
APP_VERSION=2.0.0
APP_PORT=8001
DEBUG=false
API_PREFIX=/api/v2
SECRET_KEY=__AUTO__                         # 部署时自动生成（JWT 签名密钥）
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
TESTAGENT_SECRET_KEY=__AUTO__               # 部署时自动生成（项目环境变量加密密钥）
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_USER_EMAIL=admin@test.com
DEFAULT_USER_NAME=管理员
AUTH_DEV_SECRET=
AUTH_AUDIENCE=
CORS_ORIGINS=["http://localhost"]
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW=60
PAGINATION_DEFAULT_SIZE=30
PAGINATION_MAX_SIZE=300
ATTACHMENT_MAX_SIZE=52428800

# ---------- 大语言模型 ----------
DEEPSEEK_API_KEY=CHANGE_ME_deepseek_key     # 【!】
LLM_MODEL=deepseek-v4-flash
IMAGE_PARSER_API_BASE=https://ark.cn-beijing.volces.com/api/v3   # 【?】豆包 Vision 等 OpenAI 兼容接口
IMAGE_PARSER_API_KEY=CHANGE_ME_image_parser_key                  # 【!】
IMAGE_PARSER_MODEL=doubao-seed-2-0-mini-260428
ENABLE_PDF_MULTIMODAL=true

# ---------- LangSmith 可观测性（默认关闭） ----------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=new-agent

# ---------- Agent 运行时 ----------
WEB_MCP_HEADLESS=true

# ---------- 前端构建参数（docker compose build 时插值进 ui 镜像，改后必须重建 ui） ----------
NEXT_PUBLIC_LANGGRAPH_API_URL=http://AUTO_DETECT_IP/langgraph   # 部署时自动替换为本机 IP；也可手动改
NEXT_PUBLIC_API_URL=
# 留空 = 浏览器同源相对路径（推荐）
NEXT_PUBLIC_TESTCASE_GENERATOR_ASSISTANT_ID=testcase_generator_agent

# ---------- RAG 服务链 ----------
RAG_MCP_URL=http://rag-server:8008/sse
RAG_USERNAME=admin
RAG_PASSWORD=__AUTO__                       # 部署时自动生成（与 lightrag AUTH_ACCOUNTS 同步）
RAG_SPACE_ID=cmp_space
NEO4J_PASSWORD=__AUTO__                     # 部署时自动生成
LIGHTRAG_PUBLISH_PORT=9621
HF_ENDPOINT=https://hf-mirror.com
