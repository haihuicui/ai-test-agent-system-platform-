# ==========================================================================
# LightRAG 服务配置（部署时由 deploy/deploy.sh 自动生成并填充随机密码）
# 外部 API key 标注 【!】，需手动填写
# 本文件挂载进 lightrag 容器 /app/.env（只读）
# ==========================================================================

# ---------- 服务基础 ----------
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE='但问智能知识库'
WEBUI_DESCRIPTION="Simple and Fast Graph Based RAG System"
SPACE_MANAGEMENT_ENABLED=true

# ---------- 认证 ----------
# admin 密码、TOKEN_SECRET 由 deploy.sh 自动生成并与 deploy/.env 同步
AUTH_ACCOUNTS='admin:__AUTO__'
TOKEN_SECRET=__AUTO__
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_HOURS=48

# ---------- LLM（DeepSeek） ----------
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.deepseek.com/v1
LLM_BINDING_API_KEY=CHANGE_ME_deepseek_key      # 【!】

# ---------- Embedding（阿里云 DashScope，1024 维——与 Milvus 集合维度绑定，勿改模型） ----------
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BINDING_API_KEY=CHANGE_ME_dashscope_key   # 【!】
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
EMBEDDING_TIMEOUT=600

# ---------- Rerank（阿里云） ----------
RERANK_BINDING=aliyun
RERANK_MODEL=gte-rerank-v2
RERANK_BINDING_HOST=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_BINDING_API_KEY=CHANGE_ME_dashscope_key      # 【!】通常与 EMBEDDING 同一把 key
MIN_RERANK_SCORE=0.0
RERANK_BY_DEFAULT=True
RELATED_CHUNK_NUMBER=6

# ---------- VLM（图片解析，火山引擎） ----------
VLM_PROCESS_ENABLE=true
VLM_LLM_BINDING=openai
VLM_LLM_MODEL=doubao-seed-1-6-vision-250815
VLM_LLM_BINDING_HOST=https://ark.cn-beijing.volces.com/api/v3
VLM_LLM_BINDING_API_KEY=CHANGE_ME_volces_key        # 【!】

# ---------- 文档解析（Docling） ----------
LIGHTRAG_PARSER=pdf:docling
MULTIMODAL_PARSER=docling
DOCLING_ENDPOINT=http://docling:5001
DOCLING_DO_OCR=true

# ---------- 检索与分块 ----------
TOP_K=40
CHUNK_TOP_K=20
MAX_ENTITY_TOKENS=6000
MAX_RELATION_TOKENS=8000
MAX_TOTAL_TOKENS=30000
KG_CHUNK_PICK_METHOD=VECTOR
ENABLE_LLM_CACHE_FOR_EXTRACT=true
SUMMARY_LANGUAGE=Chinese
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100
MAX_EXTRACT_INPUT_TOKENS=61440
WORKER_TIMEOUT=300
FUNC_TIMEOUT=300
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2

# ---------- 存储后端（全部指向 compose 服务，名称不变） ----------
LIGHTRAG_KV_STORAGE=RedisKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_VECTOR_STORAGE=MilvusVectorDBStorage

REDIS_URI=redis://redis:6379
REDIS_SOCKET_TIMEOUT=50
REDIS_CONNECT_TIMEOUT=60
REDIS_MAX_CONNECTIONS=100
REDIS_RETRY_ATTEMPTS=3

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__AUTO__                         # 部署时自动生成
POSTGRES_DATABASE=lightrag
POSTGRES_MAX_CONNECTIONS=12
POSTGRES_ENABLE_VECTOR=false

NEO4J_URI=neo4j://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=__AUTO__                            # 部署时自动生成

MILVUS_URI=http://milvus:19530
MILVUS_DB_NAME=lightrag
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_METRIC_TYPE=COSINE
